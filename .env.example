# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` next to docker-compose.prod.yml on the server. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Public domain + Let's Encrypt contact. Point an A record at the VPS IP first —
# Caddy issues the certificate on first boot and fails if the domain doesn't resolve.
DOMAIN=lexify.example.com
ACME_EMAIL=you@example.com

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# Connection strings (used by backend service)
DATABASE_URL=Host=postgres;Port=5432;Database=lexify;Username=lexify;Password=change_me_strong_password
REDIS_URL=redis:6379,password=change_me_redis_password

# JWT
JWT_SECRET=change_me_min_32_chars_secret_key_here
JWT_ISSUER=lexify
JWT_AUDIENCE=lexify
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# Admin account (seeded on first start)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!
ADMIN_DISPLAY_NAME=Admin

# Transactional email — REQUIRED for public use: without it password reset and welcome
# mail silently fail. Any SMTP provider works (Resend, Brevo, Mailgun, SendGrid…).
# Example below is Resend; use its SMTP credentials, not the REST API key.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_USERNAME=resend
SMTP_PASSWORD=change_me_smtp_password
SMTP_FROM_ADDRESS=noreply@lexify.example.com
SMTP_FROM_NAME=Lexify

# Ollama Cloud (https://ollama.com) — OpenAI-compatible inference
# Create/rotate the key at https://ollama.com  (Account → API keys). Never commit the real value.
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma3:27b

# ── Backups ──────────────────────────────────────────────────────────────────
# Local dumps (fast restore) + offsite copies (survive losing the VPS).
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# Offsite target — any S3-compatible store (AWS S3, Backblaze B2, Cloudflare R2, MinIO).
# B2 example: https://s3.us-west-004.backblazeb2.com
BACKUP_OFFSITE_CRON=0 4 * * *
BACKUP_OFFSITE_RETENTION_DAYS=30
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_BUCKET=lexify-backups
S3_ACCESS_KEY_ID=change_me
S3_SECRET_ACCESS_KEY=change_me

# Monitoring (docker-compose.monitoring.yml)
GRAFANA_PASSWORD=change_me_grafana_password
