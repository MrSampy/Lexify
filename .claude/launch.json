{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend",
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "backend/src/Lexify.API", "--launch-profile", "http"],
      "port": 5216,
      "autoPort": false
    }
  ]
}
