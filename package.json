{
  "name": "lexify",
  "version": "1.0.0",
  "description": "AI-powered word learning platform with spaced repetition",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "frontend/node_modules/.bin/eslint --fix --config frontend/eslint.config.js",
      "frontend/node_modules/.bin/prettier --write"
    ],
    "frontend/src/**/*.{css,json,md}": [
      "frontend/node_modules/.bin/prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7"
  }
}
